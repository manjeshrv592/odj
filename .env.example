# ─────────────────────────────────────────────────────────────────────────────
# ODJ environment variables
# Copy this file to `.env` (repo root) and fill in real values.
# `.env` is git-ignored. Node loads it via `--env-file=.env` (no dotenv dependency).
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Backend (Express) ────────────────────────────────────────────────────────
# Port the Express API listens on.
PORT=4000

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# Local PostgreSQL 18. Create the `odj` database first (see README/CLAUDE.md).
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/odj

# ── better-auth ──────────────────────────────────────────────────────────────
# Long random secret used to sign sessions/tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=replace-with-a-long-random-string
# Public base URL of the auth server (the Express backend).
BETTER_AUTH_URL=http://localhost:4000

# ── Email (Resend) — used for email OTP ──────────────────────────────────────
RESEND_API_KEY=re_replace_me
# Verified sender address in Resend (e.g. "ODJ <no-reply@yourdomain.com>").
EMAIL_FROM=ODJ <onboarding@resend.dev>

# ── CORS / clients ───────────────────────────────────────────────────────────
# Web origin allowed to call the API (Next.js dev server).
WEB_ORIGIN=http://localhost:3000
# Deep-link scheme for the mobile app (used in better-auth trustedOrigins).
MOBILE_SCHEME=odj

# ── Web (Next.js) — must be prefixed NEXT_PUBLIC_ to reach the browser ────────
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── Mobile (Expo) — must be prefixed EXPO_PUBLIC_ to reach the app ────────────
EXPO_PUBLIC_API_URL=http://localhost:4000

ROOT_USER_EMAIL=root@odj.dev
