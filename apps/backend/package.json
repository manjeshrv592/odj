{
  "name": "@odj/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "node --env-file=../../.env --import tsx --watch src/index.ts",
    "start": "node --env-file=../../.env --import tsx src/index.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo *.tsbuildinfo",
    "auth:generate": "pnpm dlx @better-auth/cli@latest generate --config src/auth/index.ts --output src/db/auth-schema.ts -y",
    "db:ensure": "node --env-file=../../.env scripts/ensure-db.mjs",
    "db:setup": "pnpm db:ensure && pnpm db:migrate",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@better-auth/expo": "^1.6.20",
    "@odj/shared": "workspace:*",
    "better-auth": "^1.6.20",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "express": "^5.2.1",
    "pg": "^8.22.0",
    "resend": "^6.14.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3"
  }
}
