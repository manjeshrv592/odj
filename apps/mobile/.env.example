# Mobile (Expo) environment — copy to apps/mobile/.env and fill values.
#
# Expo only auto-loads a .env from THIS app directory, not the monorepo root, so
# EXPO_PUBLIC_* vars live here (the backend's root .env is loaded separately via
# `node --env-file`). EXPO_PUBLIC_* values are inlined into the JS bundle at build
# time — restart Metro with `expo start -c` after changing them.

# Uploadcare public key for profile-photo + document uploads (same value as the
# web app's NEXT_PUBLIC_UPLOADCARE_PUBLIC_KEY). Dashboard → API keys → Public Key.
EXPO_PUBLIC_UPLOADCARE_PUBLIC_KEY=

# Backend base URL. Leave UNSET for local dev: api.ts auto-detects the LAN host the
# device used to reach Metro, so a physical device can reach the laptop's backend.
# Set this only for staging/prod or a custom host.
# EXPO_PUBLIC_API_URL=http://localhost:4000
